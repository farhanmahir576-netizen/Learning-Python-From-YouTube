# A function to find in which line of the file does a word occur first

w = input("enter word= ")

def check_for_line():
	word = w
	data = True
	line_no = 1
	with open("practice.txt", "r") as f:
		while data:
			data = f.readline()
			if (word in data):
				print(line_no)
				return
			line_no += 1
	return -1
print(check_for_line())
