# Create student class that takes name and marks of three subjects as arguments in contractor. Then create a method to print the average.

class Student:
	def __init__(self, name, marks):
		self.name = name
		self.marks = marks
		
	def get_avg(self):
		sum = 0
		for val in self.marks:
			sum += val
		print("Hi", self.name, "your avg score is: ", sum/3)

s1 = Student("Alif", [44,55,66])
s1.get_avg()
