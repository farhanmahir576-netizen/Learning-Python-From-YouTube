# Define a Employee class with attributes role, department and salary. This class also a showDetails() method.
# Create an Engineer class that inherits properties from Employee and has additional attributes: name and age.
class Employee:
	def __init__(self, role, dept, salary):
		self.role = role
		self.dept = dept
		self.salary = salary
	
	def showDetails(self):
		print("role = ", self.role)
		print("dept = ", self.dept)
		print("salary = ", self.salary)

class Engineer(Employee):
	def __init__(self, name, age):
		self.name = name
		self.age = age
		super().__init__("Engineer", "IT", "42000")	
		
emp1 = Employee("Accountant", "Finance", "35000")
emp1.showDetails()
eng1 = Engineer("Alif", 35)
eng1.showDetails()
